{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://brewsignal.io/schemas/recipe-v2.0.json",
  "additionalProperties": true,
  "description": "BrewSignal Recipe Format v2 envelope (tilt_ui-cnzl / tilt_ui-0jkg).\n\nv2 = a BeerJSON-1.0-shaped `recipe` block plus one namespaced\n`brewsignal` block. The recipe block is intentionally typed as a dict:\nBeerJSON structure is validated by the existing BeerJSON validator on\nimport, not re-modeled here. Stripping the `brewsignal` block must\nleave a document any BeerJSON tool can read (design doc \u00a77.1).",
  "properties": {
    "brewsignal_version": {
      "title": "Brewsignal Version",
      "type": "string"
    },
    "based_on": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Based On"
    },
    "recipe": {
      "additionalProperties": true,
      "title": "Recipe",
      "type": "object"
    },
    "brewsignal": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Brewsignal"
    },
    "notes": {
      "anyOf": [
        {
          "maxLength": 10000,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Notes"
    },
    "created_at": {
      "anyOf": [
        {
          "maxLength": 30,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Created At"
    }
  },
  "required": [
    "brewsignal_version",
    "recipe"
  ],
  "title": "BrewSignalRecipeV2",
  "type": "object"
}
