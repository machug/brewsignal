  "brewsignal": {
    "schema": "brewsignal/2.0",
    "style_id": "bjcp-2021-21c",

    "hop_additions": [
      { "index": 0, "name": "Citra", "ref_use": "add_to_boil", "hop_use": "boil", "purpose": "bittering" },
      {
        "index": 1, "name": "Citra", "ref_use": "add_to_boil",
        "hop_use": "whirlpool",
        "purpose": "aroma",
        "temperature": { "value": 79.0, "unit": "C" },
        "stand_time": { "value": 20, "unit": "min" },
        "_note": "Hot side cooled to 79C before this 162g charge — NOT a 20-min boil. brewsignal.hop_use overrides the BeerJSON add_to_boil fallback."
      },
      {
        "index": 2, "name": "Citra", "ref_use": "add_to_fermentation",
        "hop_use": "dry_hop",
        "purpose": "biotransformation",
        "dry_hop_stage": 1,
        "trigger": "warm_post_primary",
        "temperature": { "value": 15.5, "unit": "C" },
        "day_offset": { "value": 8, "unit": "day" },
        "oil_content": {
          "_source": "typical Citra variety values, not lot-specific",
          "total_oil_ml_per_100g": 2.5,
          "myrcene": 60, "humulene": 12, "caryophyllene": 7, "farnesene": 1
        }
      }
    ],

    "water": {
      "target_profile": {
        "name": "Hazy build (chloride-forward)",
        "calcium_ppm": null,
        "magnesium_ppm": null,
        "sodium_ppm": null,
        "chloride_ppm": 125,
        "sulfate_ppm": 75,
        "bicarbonate_ppm": null,
        "sulfate_chloride_ratio": 0.6,
        "_note": "0.6 SO4:Cl = chloride-forward, soft/round — opposite of a sulfate-forward West Coast IPA."
      },
      "adjustments": [
        {
          "stage": "mash",
          "salts": { "calcium_chloride_g": null, "calcium_sulfate_g": null },
          "computed_by": "water_tool",
          "_note": "Brewer specified targets + salts (CaCl2 + gypsum); gram doses to be computed by the water calculator (tilt_ui-w5kd) from source water + volume."
        }
      ],
      "mash_ph_target": 5.2
    },

    "process": {
      "lodo": true,
      "closed_transfer": true,
      "pressure_fermentation": false,
      "_note": "Closed/pressure transfer throughout to avoid oxidation — critical for hazy stability."
    },

    "nutrition": null,
    "inventory": null,

    "fermentation_tracking": {
      "og_validation": { "enabled": true, "tolerance_sg": 0.003 },
      "fg_prediction": { "enabled": true, "ml_model": "kalman_exponential" },
      "anomaly_detection": {
        "stuck_fermentation": true,
        "temperature_alerts": true,
        "min_sg_change_24h": 0.001,
        "hop_creep_watch": true
      }
    },
    "batch_defaults": {
      "auto_link_device": true,
      "temperature_control": {
        "enabled": true,
        "target_c": 20.0,
        "hysteresis_c": 0.5,
        "min_cycle_time_minutes": 5
      }
    },
    "yeast_management": {
      "pitch_rate_million_cells_ml_plato": 0.35,
      "starter_required": true
    }
  },

  "notes": "All-Citra Fidens 'Jasper' DIPA clone, 19L. Plain-language brew steps; ALL machine-actionable technique now lives in structured fields above (was free-text in v1): 79C/20min whirlpool (brewsignal.hop_additions[1]), warm 15.5C biotransformation dry hop day 8 (brewsignal.hop_additions[2]), chloride-forward water build 125/75 (brewsignal.water), LODO closed transfer (brewsignal.process).",
