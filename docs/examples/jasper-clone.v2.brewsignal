          "alpha_acid": { "value": 11.0, "unit": "%" },
          "amount": { "value": 162.0, "unit": "g" },
          "timing": { "use": "add_to_boil", "duration": { "value": 20, "unit": "min" } }
        },
        {
          "name": "Citra",
          "origin": "United States",
          "form": "pellet",
          "alpha_acid": { "value": 11.0, "unit": "%" },
          "amount": { "value": 209.0, "unit": "g" },
          "timing": {
            "use": "add_to_fermentation",
            "time": { "value": 8, "unit": "day" },
            "duration": { "value": 5, "unit": "day" }
          }
        }
      ],

      "culture_additions": [
        {
          "name": "London Ale III",
          "type": "ale",
          "form": "liquid",
